    views: "3,120",
    emoji: "\ud83d\udcc8",
    gradient: "linear-gradient(135deg, #0A1628, #1A3A5C)",
    image: "article_stocks_quant_2_1776245068123.png",
    featured: false,
    breadcrumb: "\u0627\u0644\u0623\u0633\u0647\u0645",
    breadcrumbEn: "Stocks",
    breadcrumbHref: "index.html#strategies",
    toc: [
      { id: "quant-logic", text: "\u0627\u0644\u0645\u0646\u0637\u0642 \u0627\u0644\u0643\u0645\u064a \u0645\u0642\u0627\u0628\u0644 \u0627\u0644\u0639\u0627\u0637\u0641\u064a" },
      { id: "risk-parity", text: "\u062a\u0648\u0627\u0632\u0646 \u0627\u0644\u0645\u062e\u0627\u0637\u0631 (Risk Parity)" },
      { id: "hedging", text: "\u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0627\u062a \u0627\u0644\u062a\u062d\u0648\u0637 \u0627\u0644\u0628\u0631\u0645\u062c\u064a" },
      { id: "backtesting", text: "\u0623\u0647\u0645\u064a\u0629 \u0627\u0644\u0627\u062e\u062a\u0628\u0627\u0631 \u0627\u0644\u0639\u0643\u0633\u064a (Backtesting)" },
    ],
    tocEn: [
      { id: "quant-logic", text: "Quant Logic vs. Emotional" },
