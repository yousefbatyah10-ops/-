    title: "\u0627\u0644\u0625\u0642\u0631\u0627\u0636 \u0645\u0646 \u0646\u0638\u064a\u0631 \u0644\u0646\u0638\u064a\u0631: \u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0627\u062a \u0627\u0644\u0639\u0627\u0626\u062f \u0627\u0644\u0645\u0631\u062a\u0641\u0639 \u0641\u064a \u0627\u0642\u062a\u0635\u0627\u062f \u0627\u0644\u0627\u0626\u062a\u0645\u0627\u0646 \u0627\u0644\u0628\u062f\u064a\u0644",
    titleEn: "Peer-to-Peer Lending: Risk vs. Reward in New Credit",
    summary: "\u0643\u0646 \u0623\u0646\u062a \u0627\u0644\u0628\u0646\u0643. \u0643\u064a\u0641 \u062a\u0648\u0632\u0639 \u0631\u0623\u0633 \u0645\u0627\u0644\u0643 \u0644\u0625\u0642\u0631\u0627\u0636 \u0627\u0644\u0623\u0641\u0631\u0627\u062f \u0648\u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0646\u0627\u0634\u0626\u0629 \u0645\u0642\u0627\u0628\u0644 \u0639\u0648\u0627\u0626\u062f \u062a\u0641\u0648\u0642 \u0627\u0644\u0648\u062f\u0627\u0626\u0639 \u0627\u0644\u0628\u0646\u0643\u064a\u0629 \u0627\u0644\u062a\u0642\u0644\u064a\u062f\u064a\u0629 \u0628\u062b\u0644\u0627\u062b\u0629 \u0623\u0636\u0639\u0627\u0641.",
    summaryEn: "Be the bank. How to allocate capital for lending to individuals and startups for yields triple that of traditional deposits.",
    excerpt: "\u062a\u0639\u0644\u0645 \u0643\u064a\u0641 \u062a\u0642\u064a\u0645 \u0627\u0644\u062c\u062f\u0627\u0631\u0629 \u0627\u0644\u0627\u0626\u062a\u0645\u0627\u0646\u064a\u0629 \u0631\u0642\u0645\u064a\u0627\u064b\u060c \u0648\u0643\u064a\u0641 \u062a\u0648\u0632\u0639 \u0645\u062e\u0627\u0637\u0631\u0643 \u0639\u0628\u0631 \u0645\u0626\u0627\u062a \u0627\u0644\u0642\u0631\u0648\u0636 \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u0644\u0636\u0645\u0627\u0646 \u062a\u062f\u0641\u0642 \u0646\u0642\u062f\u064a \u0645\u0633\u062a\u0642\u0631 \u0648\u0639\u0627\u0626\u062f \u062a\u0631\u0627\u0643\u0645\u064a \u0645\u0631\u062a\u0641\u0639.",
