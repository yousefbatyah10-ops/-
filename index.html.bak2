    title: "\u0627\u0644\u0628\u064a\u062a\u0643\u0648\u064a\u0646 \u0643\u0623\u0635\u0644 \u0627\u062d\u062a\u064a\u0627\u0637\u064a: \u0644\u0645\u0627\u0630\u0627 \u062a\u0636\u0639 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u062b\u0631\u0648\u0627\u062a\u0647\u0627 \u0641\u064a \u0627\u0644\u0630\u0647\u0628 \u0627\u0644\u0631\u0642\u0645\u064a\u061f",
    titleEn: "Bitcoin as a Treasury Reserve: Why Corporations are Locking Balance Sheets",
    summary: "\u062a\u062d\u0648\u0644 \u062a\u0627\u0631\u064a\u062e\u064a \u0641\u064a \u0627\u0644\u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629. \u0644\u0645\u0627\u0630\u0627 \u062a\u062e\u0644\u062a '\u0645\u0627\u064a\u0643\u0631\u0648\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a' \u0648\u063a\u064a\u0631\u0647\u0627 \u0639\u0646 \u0627\u0644\u0646\u0642\u062f \u0627\u0644\u062a\u0642\u0644\u064a\u062f\u064a \u0644\u0635\u0627\u0644\u062d \u0627\u0644\u0628\u064a\u062a\u0643\u0648\u064a\u0646 \u0648\u0643\u064a\u0641 \u062a\u062d\u0645\u064a \u0647\u0630\u0647 \u0627\u0644\u062e\u0637\u0648\u0629 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0645\u0646 \u0627\u0644\u062a\u0636\u062e\u0645.",
