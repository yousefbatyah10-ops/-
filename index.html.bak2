<!-- النشرة البريدية -->
<section class="newsletter-section" id="newsletter" aria-labelledby="newsletter-title">
  <div class="container">
    <div class="newsletter-box">
      <span class="newsletter-icon" aria-hidden="true">💌</span>
      <h2 class="newsletter-title" id="newsletter-title">
        <span data-i18n="newsletter.title1">انضم إلى</span> <span data-i18n="newsletter.title2">نخبة المستثمرين</span>
      </h2>
      <p class="newsletter-desc" data-i18n="newsletter.desc">
        احصل على أفضل التحليلات المالية والفرص الاستثمارية مباشرة في بريدك كل أسبوع — مجاناً وبدون إزعاج
      </p>
      <form class="newsletter-form" id="newsletterForm" novalidate action="MAILCHIMP_ACTION_URL" method="post" target="_blank">
        <div style="position:absolute; left:-5000px;" aria-hidden="true">
          <input type="text" name="b_XXXXXXXX_XXXXXXXX" tabindex="-1" value="">
        </div>
        <input type="email" class="newsletter-input" id="emailInput" name="EMAIL" placeholder="بريدك الإلكتروني..." data-i18n="newsletter.placeholder" autocomplete="email" aria-label="البريد الإلكتروني" required />
        <button type="submit" class="btn-primary" id="subscribe-submit-btn" data-i18n="newsletter.btn">
          اشترك الآن ✦
        </button>
      </form>
      <div class="newsletter-perks" role="list" aria-label="مميزات الاشتراك">
        <div class="perk" role="listitem">
          <span class="perk-icon" aria-hidden="true">✓</span>
          <span data-i18n="newsletter.perk1">بريد أسبوعي فقط</span>
        </div>
        <div class="perk" role="listitem">
          <span class="perk-icon" aria-hidden="true">✓</span>
          <span data-i18n="newsletter.perk2">لا إعلانات مزعجة</span>
        </div>
        <div class="perk" role="listitem">
          <span class="perk-icon" aria-hidden="true">✓</span>
          <span data-i18n="newsletter.perk3">إلغاء في أي وقت</span>
        </div>
        <div class="perk" role="listitem">
          <span class="perk-icon" aria-hidden="true">✦</span>
          <span data-i18n="newsletter.perk4">مجاني للأبد</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- الفوتر -->
<footer class="footer" id="footer" role="contentinfo">
  <div class="container" style="padding-top: 0; padding-bottom: 0;">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="index.html" class="logo" aria-label="ملتقى الأثرياء">
          <div class="logo-icon" aria-hidden="true">💎</div>
          <div>
            <span class="logo-text" data-i18n="logo.text">ملتقى الأثرياء</span>
            <span class="logo-sub" data-i18n="logo.sub">النخبة المالية العربية</span>
          </div>
        </a>
        <p data-i18n="footer.brand.desc">منصة محتوى مالي متخصصة تهدف إلى تمكين المستثمر العربي من اتخاذ قرارات مالية واثقة ومدروسة.</p>
