    title: "\u0645\u0643\u062a\u0628 \u0627\u0644\u0645\u064a\u062a\u0627\u0641\u064a\u0631\u0633: \u062a\u0639\u0627\u0648\u0646 \u0639\u0627\u0644\u0645\u064a \u064a\u062a\u062c\u0627\u0648\u0632 \u062d\u062f\u0648\u062f \u0645\u0643\u0627\u0644\u0645\u0627\u062a \u0627\u0644\u0641\u064a\u062f\u064a\u0648",
    titleEn: "The Metaverse Office: Remote Collaboration beyond Video",
    summary: "\u0643\u064a\u0641 \u064a\u063a\u064a\u0631 \u0627\u0644\u0648\u0627\u0642\u0639 \u0627\u0644\u0627\u0641\u062a\u0631\u0627\u0636\u064a \u0648\u0627\u0644\u0645\u0639\u0632\u0632 \u0637\u0631\u064a\u0642\u0629 \u0639\u0645\u0644 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0643\u0628\u0631\u0649\u061f \u0627\u0633\u062a\u0643\u0634\u0641 \u0643\u064a\u0641 \u062a\u0631\u0641\u0639 \u0628\u064a\u0626\u0627\u062a \u0627\u0644\u0639\u0645\u0644 \u062b\u0644\u0627\u062b\u064a\u0629 \u0627\u0644\u0623\u0628\u0639\u0627\u062f \u0645\u0646 \u0627\u0644\u0625\u0646\u062a\u0627\u062c\u064a\u0629 \u0648\u062a\u0642\u0644\u0644 \u0627\u0644\u062a\u0643\u0627\u0644\u064a\u0641.",
