    title: "\u0633\u064a\u0643\u0648\u0644\u0648\u062c\u064a\u0629 \u0627\u0644\u062a\u062d\u0648\u0637: \u0625\u062a\u0642\u0627\u0646 \u0627\u0644\u0627\u0646\u062d\u064a\u0627\u0632 \u0627\u0644\u0639\u0643\u0633\u064a \u0641\u064a \u0627\u0644\u0623\u0633\u0648\u0627\u0642 \u0627\u0644\u0647\u0627\u0628\u0637\u0629",
    titleEn: "Psychological Edge: Master the Contrarian Bias in Bear Markets",
    summary: "\u0639\u0646\u062f\u0645\u0627 \u064a\u062e\u0627\u0641 \u0627\u0644\u062c\u0645\u064a\u0639\u060c \u064a\u062c\u062f \u0627\u0644\u0645\u0633\u062a\u062b\u0645\u0631 \u0627\u0644\u0630\u0643\u064a \u0627\u0644\u0641\u0631\u0635\u0629. \u0643\u064a\u0641 \u062a\u062f\u0631\u0628 \u0639\u0642\u0644\u0643 \u0639\u0644\u0649 \u0634\u0631\u0627\u0621 \u0627\u0644\u0623\u0635\u0648\u0644 \u0639\u0646\u062f\u0645\u0627 \u064a\u0628\u064a\u0639\u0647\u0627 \u0627\u0644\u0622\u062e\u0631\u0648\u0646 \u0628\u0630\u0639\u0631\u060c \u0648\u0644\u0645\u0627\u0630\u0627 \u064a\u0639\u062a\u0628\u0631 \u0627\u0644\u0627\u0646\u062d\u064a\u0627\u0632 \u0627\u0644\u0639\u0643\u0633\u064a \u0633\u0631 \u0627\u0644\u062b\u0631\u0648\u0627\u062a \u0627\u0644\u0643\u0628\u0631\u0649.",
    summaryEn: "When everyone is afraid, the smart investor finds opportunities. How to train your mind to buy assets when others panically sell.",
    excerpt: "\u062a\u0639\u0644\u0645 \u0643\u064a\u0641 \u062a\u0633\u062a\u0641\u064a\u062f \u0645\u0646 \u062f\u0648\u0631\u0627\u062a \u0627\u0644\u062e\u0648\u0641 \u0648\u0627\u0644\u0646\u0634\u0648\u0629 \u0641\u064a \u0627\u0644\u0633\u0648\u0642\u060c \u0648\u0627\u0643\u062a\u0634\u0641 \u0644\u0645\u0627\u0630\u0627 \u064a\u0639\u062a\u0628\u0631 \u0627\u0644\u0634\u0631\u0627\u0621 \u0641\u064a \u0630\u0631\u0648\u0629 \u0627\u0644\u062a\u0634\u0627\u0624\u0645 \u0647\u0648 \u0627\u0644\u0637\u0631\u064a\u0642 \u0627\u0644\u0623\u0633\u0631\u0639 \u0644\u0628\u0646\u0627\u0621 \u0627\u0644\u062b\u0631\u0648\u0629 \u0627\u0644\u062d\u0642\u064a\u0642\u064a\u0629.",
