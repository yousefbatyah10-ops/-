window.ARTICLES = window.ARTICLES || [
  {
    id: 1,
    slug: "smart-wealth-portfolio-2026",
    title: "\u062f\u0644\u064a\u0644 \u0627\u0644\u062b\u0631\u0648\u0629 \u0627\u0644\u0630\u0643\u064a\u0629: \u0643\u064a\u0641 \u062a\u0628\u0646\u064a \u0645\u062d\u0641\u0638\u0629 \u0627\u0633\u062a\u062b\u0645\u0627\u0631\u064a\u0629 \u0645\u062a\u0648\u0627\u0632\u0646\u0629 \u0641\u064a 2026",
    titleEn: "Smart Wealth Guide: How to Build a Balanced Investment Portfolio in 2026",
    summary: "\u0641\u064a \u0638\u0644 \u0627\u0644\u062a\u0642\u0644\u0628\u0627\u062a \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0629 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629\u060c \u0623\u0635\u0628\u062d \u0628\u0646\u0627\u0621 \u0645\u062d\u0641\u0638\u0629 \u0627\u0633\u062a\u062b\u0645\u0627\u0631\u064a\u0629 \u0645\u062a\u0648\u0627\u0632\u0646\u0629 \u0636\u0631\u0648\u0631\u0629 \u062d\u062a\u0645\u064a\u0629. \u0646\u0633\u062a\u0639\u0631\u0636 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u062f\u0644\u064a\u0644 \u0627\u0644\u0634\u0627\u0645\u0644 \u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0627\u062a \u0627\u0644\u062a\u0646\u0648\u064a\u0639 \u0627\u0644\u0623\u0630\u0643\u0649 \u0644\u0644\u0645\u0633\u062a\u062b\u0645\u0631 \u0627\u0644\u0639\u0631\u0628\u064a \u0648\u0623\u0641\u0636\u0644 \u0641\u0626\u0627\u062a \u0627\u0644\u0623\u0635\u0648\u0644 \u0644\u062a\u062d\u0642\u064a\u0642 \u0646\u0645\u0648 \u0645\u0633\u062a\u062f\u0627\u0645.",
    summaryEn: "In light of global economic volatility, building a balanced investment portfolio has become an imperative. In this comprehensive guide, we review the smartest diversification strategies for the Arab investor and the best asset classes for achieving sustainable growth.",
    excerpt: "\u0641\u064a \u0638\u0644 \u0627\u0644\u062a\u0642\u0644\u0628\u0627\u062a \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0629 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629\u060c \u0623\u0635\u0628\u062d \u0628\u0646\u0627\u0621 \u0645\u062d\u0641\u0638\u0629 \u0627\u0633\u062a\u062b\u0645\u0627\u0631\u064a\u0629 \u0645\u062a\u0648\u0627\u0632\u0646\u0629 \u0636\u0631\u0648\u0631\u0629 \u0644\u0627 \u062e\u064a\u0627\u0631\u0627\u064b. \u0646\u0633\u062a\u0639\u0631\u0636 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u062f\u0644\u064a\u0644 \u0627\u0644\u0634\u0627\u0645\u0644 \u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0627\u062a \u0627\u0644\u062a\u0646\u0648\u064a\u0639 \u0627\u0644\u0623\u0630\u0643\u0649 \u0644\u0644\u0645\u0633\u062a\u062b\u0645\u0631 \u0627\u0644\u0639\u0631\u0628\u064a\u060c \u0645\u0639 \u062a\u062d\u0644\u064a\u0644 \u0639\u0645\u064a\u0642 \u0644\u0623\u0641\u0636\u0644 \u0641\u0626\u0627\u062a \u0627\u0644\u0623\u0635\u0648\u0644 \u0623\u062f\u0627\u0621\u064b \u0641\u064a \u0627\u0644\u0633\u0646\u0648\u0627\u062a \u0627\u0644\u0642\u0627\u062f\u0645\u0629.",
    excerptEn: "In the face of global economic fluctuations, a balanced portfolio is a necessity. We explore the smartest diversification strategies with a deep dive into the best-performing asset classes.",
    category: "\u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0627\u062a \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631",
    categoryEn: "Investment Strategies",
    categoryIcon: "\ud83d\udcca",
