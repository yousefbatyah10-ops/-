    content: `
      <h2 id="asset-protection-walls">\u062c\u062f\u0631\u0627\u0646 \u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0623\u0635\u0648\u0644</h2>
      <p>\u0627\u0644\u0647\u062f\u0641 \u0645\u0646 \u0627\u0644\u0647\u064a\u0643\u0644\u0629 \u0627\u0644\u0645\u062a\u0642\u062f\u0645\u0629 \u0648\u0635\u0646\u0627\u062f\u064a\u0642 \u0627\u0644\u0623\u0645\u0627\u0646\u0627\u062a (Trusts) \u0644\u064a\u0633 \u0627\u0644\u062a\u0647\u0631\u0628\u060c \u0628\u0644 \u0636\u0645\u0627\u0646 \u0623\u0646 \u0627\u0644\u0627\u0644\u062a\u0632\u0627\u0645\u0627\u062a \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0644\u0627 \u062a\u0624\u062b\u0631 \u0639\u0644\u0649 \u0627\u0644\u0643\u064a\u0627\u0646 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u064a \u0627\u0644\u0630\u064a \u062a\u0639\u062a\u0645\u062f \u0639\u0644\u064a\u0647 \u0627\u0633\u062a\u062f\u0627\u0645\u0629 \u0627\u0644\u0639\u0627\u0626\u0644\u0629 \u0639\u0628\u0631 \u0627\u0644\u0623\u062c\u064a\u0627\u0644.</p>
      
      <h2 id="dynastic-legacy">\u0628\u0646\u0627\u0621 \u0627\u0644\u0625\u0631\u062b \u0627\u0644\u0639\u0627\u0626\u0644\u064a</h2>
      <p>\u0627\u0644\u0647\u064a\u0643\u0644\u0629 \u0627\u0644\u0635\u062d\u064a\u062d\u0629 \u062a\u0633\u0645\u062d \u0628\u0646\u0642\u0644 \u0627\u0644\u062b\u0631\u0648\u0629 \u0628\u0637\u0631\u064a\u0642\u0629 \u062a\u062d\u0645\u064a \u0627\u0644\u0648\u0631\u062b\u0629 \u0645\u0646 \u0623\u0646\u0641\u0633\u0647\u0645 \u0648\u0645\u0646 \u0627\u0644\u0638\u0631\u0648\u0641 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629\u060c \u0645\u0639 \u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0648\u062d\u062f\u0629 \u0627\u0644\u0642\u0631\u0627\u0631 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u064a \u0644\u0644\u0639\u0627\u0626\u0644\u0629.</p>

      <div class="highlight-box">
        <h4>\u2696\ufe0f \u0643\u0641\u0627\u0621\u0629 \u0642\u0627\u0646\u0648\u0646\u064a\u0629</h4>
        <p>\u0627\u062e\u062a\u064a\u0627\u0631 \u0627\u0644\u0627\u062e\u062a\u0635\u0627\u0635 \u0627\u0644\u0642\u0636\u0627\u0626\u064a (Jurisdiction) \u0627\u0644\u0645\u0646\u0627\u0633\u0628 \u0647\u0648 \u062d\u062c\u0631 \u0627\u0644\u0632\u0627\u0648\u064a\u0629 \u0641\u064a \u0623\u064a \u062e\u0637\u0629 \u062c\u062f\u064a\u0629 \u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0623\u0635\u0648\u0644 \u0627\u0644\u0639\u0638\u0645\u0649.</p>
      </div>
    `,
    contentEn: `
      <h2 id="asset-protection-walls">Asset Protection Walls</h2>
      <p>The goal of advanced structuring and Trusts is not evasion, but ensuring personal liabilities don't affect the entity's long-term sustainability. It creates a legal shield around family assets.</p>
      
      <h2 id="dynastic-legacy">Dynastic Planning</h2>
      <p>Proper structure ensures wealth transfer protects heirs from external and internal risks while maintaining unified family control.</p>
    `
  }
];

/* \u062f\u0627\u0644\u0629 \u0644\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0645\u0642\u0627\u0644\u0629 \u0628\u0627\u0644\u0640 ID */
function getArticleById(id) {
  return ARTICLES.find(a => a.id === parseInt(id));
}

/* \u062f\u0627\u0644\u0629 \u0644\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0627\u0644\u0645\u0642\u0627\u0644\u0627\u062a \u0630\u0627\u062a \u0627\u0644\u0635\u0644\u0629 */
function getRelatedArticles(ids) {
  if (!ids) return [];
  return ids.map(id => ARTICLES.find(a => a.id === id)).filter(Boolean);
}

</script>
<script src="js/main.js" charset="utf-8"></script>
<script>
if (typeof initLanguage === 'function') {
  initLanguage();
} else {
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof initLanguage === 'function') initLanguage();
  });
}
</script>
<script>
(function () {
  const grid = document.getElementById('articlesGrid');
  const filterBar = document.getElementById('categoryFilter');
  if (!grid) { console.error('Articles grid not found'); return; }
  if (typeof window.ARTICLES === 'undefined' || !window.ARTICLES) {
    console.error('ARTICLES data not loaded. Check js/articles.js path and encoding.');
    // Try to recover by showing an error message to the user
    grid.innerHTML = '<p style="color:var(--gold-light); text-align:center; padding:2rem;">عذراً، لم نتمكن من تحميل المقالات. يرجى التأكد من تشغيل الموقع من مجلد صحيح.</p>';
    return;
  }

  const BATCH = 6; 
  let shown = 0;
  let currentFilter = 'all';

  // mapping categories from UI to data
  const catMap = {
    'stocks': 'الأسهم',
    'realestate': 'العقارات',
    'gold': 'الذهب والمعادن',
    'crypto': 'العملات الرقمية',
    'startup': 'ريادة الأعمال',
    'passive': 'الدخل السلبي',
    'personal': 'المالية الشخصية',
    'tech': 'تقنية وثروة'
  };

  function getFilteredArticles() {
    if (currentFilter === 'all') return window.ARTICLES;
    const targetCat = catMap[currentFilter];
    return window.window.ARTICLES.filter(a => a.category === targetCat);
  }

  function renderCard(a) {
    const lang = localStorage.getItem('site_lang') || 'ar';
    const isEn = lang === 'en';

    const title = isEn ? (a.titleEn || a.title) : a.title;
    const excerpt = isEn ? (a.excerptEn || a.excerpt) : a.excerpt;
    const category = isEn ? (a.categoryEn || a.category) : a.category;
    const date = isEn ? (a.dateEn || a.date) : a.date;
    const author = isEn ? (a.authorEn || a.author) : a.author;
    const readTimeSuffix = isEn ? 'min' : 'دقيقة';

    return `
      <a href="article.html?id=${a.id}" class="article-card fade-up" id="article-${a.id}">
        <div class="card-img-placeholder" style="background: ${a.gradient}">
          <img src="${a.image}" alt="${title}" loading="lazy" />
        </div>
        <div class="card-content">
          <div class="card-meta">
            <span class="card-cat">${category}</span>
            <span class="card-date">🗓 ${date}</span>
          </div>
          <h3 class="card-title">${title}</h3>
          <p class="card-excerpt">${excerpt}</p>
          <div class="card-footer">
            <div class="card-author">
              <div class="author-avatar">${a.authorInitial}</div>
              <span class="author-name">${author}</span>
            </div>
            <span class="read-time">⏱ ${a.readTime} ${readTimeSuffix}</span>
          </div>
        </div>
      </a>`;
  }

  function loadArticles(reset = false) {
    if (reset) {
        grid.innerHTML = '';
        shown = 0;
    }
    const filtered = getFilteredArticles();
    const end = Math.min(shown + BATCH, filtered.length);
    let html = '';
    for (let i = shown; i < end; i++) {
      html += renderCard(filtered[i]);
    }
    grid.insertAdjacentHTML('beforeend', html);
    shown = end;

    // Trigger fade-up animations
    if (window._fadeObserver) {
      grid.querySelectorAll('.fade-up:not(.visible)').forEach(el => window._fadeObserver.observe(el));
    }

    const btn = document.getElementById('load-more-btn');
    if (btn) {
      btn.style.display = (shown >= filtered.length) ? 'none' : 'inline-block';
    }
  }

  // Categories Sync logic
  function syncCategoryCounts() {
    const categories = {
        'cat-stocks': 'الأسهم',
        'cat-realestate': 'العقارات',
        'cat-gold': 'الذهب والمعادن',
        'cat-crypto': 'العملات الرقمية',
        'cat-startup': 'ريادة الأعمال',
        'cat-passive': 'الدخل السلبي',
        'cat-personal': 'المالية الشخصية',
        'cat-tech': 'تقنية وثروة'
    };

    const lang = localStorage.getItem('site_lang') || 'ar';
    const isEn = lang === 'en';

    Object.keys(categories).forEach(id => {
        const count = window.ARTICLES.filter(a => a.category === categories[id]).length;
        const el = document.getElementById(id);
        if (el) {
            const countEl = el.querySelector('.cat-count');
            if (countEl) {
                countEl.textContent = isEn ? `${count} articles` : `${count} مقالة`;
            }

            // Clicking card also filters
            el.onclick = () => {
              const catKey = id.replace('cat-', '');
              const filterBtn = filterBar.querySelector(`[data-category="${catKey}"]`);
              if (filterBtn) filterBtn.click();
              document.getElementById('articles').scrollIntoView({ behavior: 'smooth' });
            };
        }
    });

    // stats sync
    const totalEl = document.querySelector('.dynamic-total-articles');
    if (totalEl) totalEl.textContent = `${window.ARTICLES.length}+`;
  }

  // Filter Bar Events
  if (filterBar) {
    filterBar.addEventListener('click', (e) => {
        const btn = e.target.closest('.filter-btn');
        if (!btn) return;

        filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentFilter = btn.dataset.category;
        loadArticles(true);
    });
  }

  try {
    loadArticles();
    syncCategoryCounts();
    console.log('Articles initialized successfully');
  } catch (err) {
    console.error('Error during articles initialization:', err);
    if (grid) grid.innerHTML = '<p style="color:var(--gold-light); text-align:center; padding:2rem;">حدث خطأ في عرض المقالات. يرجى تحديث الصفحة أو المحاولة لاحقاً.</p>';
  }

  const loadMoreBtn = document.getElementById('load-more-btn');
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', (e) => {
      e.preventDefault();
      loadArticles();
    });
  }

  window.addEventListener('languageChanged', () => {
    loadArticles(true);
    syncCategoryCounts();
  });
})();
</script>

<style>
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

</body>
</html>