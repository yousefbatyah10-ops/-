    content: `
      <h2 id="programmable-ip">\u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0641\u0643\u0631\u064a\u0629 \u0627\u0644\u0642\u0627\u0628\u0644\u0629 \u0644\u0644\u0628\u0631\u0645\u062c\u0629</h2>
      <p>\u062a\u062d\u0648\u064a\u0644 \u0628\u0631\u0627\u0621\u0629 \u0627\u062e\u062a\u0631\u0627\u0639 \u0625\u0644\u0649 NFT \u064a\u0633\u0645\u062d \u0644\u0644\u0645\u0628\u062f\u0639 \u0628\u0627\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0646\u0633\u0628\u0629 \u0645\u0626\u0648\u064a\u0629 \u062a\u0644\u0642\u0627\u0626\u064a\u0629 \u0645\u0646 \u0643\u0644 \u0639\u0645\u0644\u064a\u0629 \u0628\u064a\u0639 \u0623\u0648 \u062a\u0631\u062e\u064a\u0635 \u0644\u0627\u062d\u0642\u0629\u060c \u062f\u0648\u0646 \u0627\u0644\u062d\u0627\u062c\u0629 \u0644\u0645\u062d\u0627\u0645\u064a\u0646 \u0648\u0648\u0633\u0637\u0627\u0621. \u0647\u0630\u0627 \u0647\u0648 "\u0627\u0642\u062a\u0635\u0627\u062f \u0627\u0644\u0645\u0628\u062f\u0639\u064a\u0646" \u0627\u0644\u062d\u0642\u064a\u0642\u064a.</p>
      
      <h2 id="tokenized-assets">\u062a\u0631\u0645\u064a\u0632 \u0627\u0644\u0623\u0635\u0648\u0644 \u0627\u0644\u0648\u0627\u0642\u0639\u064a\u0629</h2>
      <p>\u0627\u0644\u0640 NFTs \u0644\u064a\u0633\u062a \u0644\u0644\u0635\u0648\u0631 \u0641\u0642\u0637\u061b \u064a\u0645\u0643\u0646 \u0627\u0633\u062a\u0628\u062f\u0627\u0644 \u0635\u0643\u0648\u0643 \u0627\u0644\u0639\u0642\u0627\u0631\u0627\u062a\u060c \u0633\u0646\u062f\u0627\u062a \u0627\u0644\u0634\u062d\u0646\u060c \u0648\u0639\u0642\u0648\u062f \u0627\u0644\u0625\u064a\u062c\u0627\u0631 \u0628\u0631\u0645\u0648\u0632 \u0631\u0642\u0645\u064a\u0629 \u0642\u0627\u0628\u0644\u0629 \u0644\u0644\u062a\u062f\u0627\u0648\u0644 \u0641\u0648\u0631\u0627\u064b \u0639\u0644\u0649 \u0627\u0644\u0628\u0644\u0648\u0643\u0634\u064a\u0646 \u0628\u0634\u0641\u0627\u0641\u064a\u0629 \u0645\u0637\u0644\u0642\u0629.</p>

      <div class="highlight-box">
        <h4>\ud83d\udcdc \u0645\u0633\u062a\u0642\u0628\u0644 \u0627\u0644\u0639\u0642\u0648\u062f</h4>
        <p>\u0627\u0644\u0639\u0642\u062f \u0627\u0644\u0630\u0643\u064a \u0644\u0627 "\u064a\u062e\u0628\u0631\u0643" \u0628\u0645\u0627 \u062a\u0645\u0644\u0643\u0647\u060c \u0628\u0644 \u0647\u0648 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0630\u0627\u062a\u0647\u0627\u060c \u0645\u062e\u0632\u0646\u0629 \u0628\u0634\u0643\u0644 \u0644\u0627 \u064a\u0645\u0643\u0646 \u0627\u0644\u062a\u0644\u0627\u0639\u0628 \u0628\u0647 \u0623\u0648 \u062a\u0628\u062f\u064a\u0644\u0647.</p>
      </div>
    `,
    contentEn: `
      <h2 id="programmable-ip">Programmable IP</h2>
      <p>Turning a patent into an NFT allows creators to automatically receive a percentage of every subsequent sale or license. This is the true "Creator Economy."</p>
      
      <h2 id="tokenized-assets">Real World Assets (RWA)</h2>
      <p>NFTs are evolving beyond art to tokenize real estate deeds, shipping manifests, and leases, enabling instant, transparent liquidity.</p>
    `
  },
