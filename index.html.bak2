    slug: "reit-vs-physical-liquidity-trap",
    title: "\u0627\u0644\u0639\u0648\u0627\u0626\u062f \u0627\u0644\u062e\u0641\u064a\u0629 \u0644\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u062c\u0632\u0626\u064a\u0629: \u0627\u0644\u062d\u0642\u064a\u0642\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629 \u0644\u0644\u0633\u064a\u0648\u0644\u0629 \u0645\u0642\u0627\u0628\u0644 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0645\u0628\u0627\u0634\u0631\u0629",
