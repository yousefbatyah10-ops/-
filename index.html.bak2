    title: "\u0627\u0644\u0645\u0627\u0644\u0643 \u0627\u0644\u0639\u0635\u0631\u064a: \u0625\u062f\u0627\u0631\u0629 \u0645\u062d\u0641\u0638\u0629 \u0639\u0642\u0627\u0631\u0627\u062a \u0642\u0635\u064a\u0631\u0629 \u0627\u0644\u0645\u062f\u0649 \u0639\u0627\u0644\u0645\u064a\u0627\u064b \u0645\u0646 \u062d\u0627\u0633\u0648\u0628\u0643",
    titleEn: "The Modern Landlord: Managing a Global Short-Term Rental Portfolio",
