  <meta name="description" content="ملتقى الأثرياء: مدونة مالية متخصصة تقدم رؤى استثمارية حصرية، تحليلات أسواق المال، واستراتيجيات بناء الثروة للمستثمر العربي الطموح." />
  <meta name="keywords" content="استثمار, ثروة, مالية شخصية, أسواق المال, ريادة أعمال, اقتصاد, مدونة مالية عربية" />
  <meta property="og:title" content="ملتقى الأثرياء — مدونة مالية نخبوية" />
  <meta property="og:description" content="رؤى استثمارية حصرية وتحليلات مالية للمستثمر العربي الطموح" />
  <meta property="og:type" content="website" />
  
  <!-- Google Search Console Verification -->
  <meta name="google-site-verification" content="2_bFyy63ZsintiXf-6UOTl6p8cPQQCISSsmLKHDbkks" />

