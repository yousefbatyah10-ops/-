    content: `
      <h2 id="compounding-power">\u0642\u0648\u0629 \u0627\u0644\u0639\u0627\u0626\u062f \u0627\u0644\u0645\u0631\u0643\u0628</h2>
      <p>\u064a\u0642\u0648\u0644 \u0622\u064a\u0646\u0634\u062a\u0627\u064a\u0646 \u0623\u0646 \u0627\u0644\u0639\u0627\u0626\u062f \u0627\u0644\u0645\u0631\u0643\u0628 \u0647\u0648 \u0627\u0644\u062b\u0627\u0645\u0646 \u0645\u0646 \u0639\u062c\u0627\u0626\u0628 \u0627\u0644\u062f\u0646\u064a\u0627. \u0641\u064a \u0639\u0627\u0644\u0645 \u0627\u0644\u062a\u0648\u0632\u064a\u0639\u0627\u062a\u060c \u0644\u0627 \u062a\u0646\u0645\u0648 \u062b\u0631\u0648\u062a\u0643 \u0641\u0642\u0637 \u0645\u0646 \u0627\u0631\u062a\u0641\u0627\u0639 \u0633\u0639\u0631 \u0627\u0644\u0633\u0647\u0645\u060c \u0628\u0644 \u0645\u0646 \u0625\u0639\u0627\u062f\u0629 \u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0627\u0644\u0623\u0631\u0628\u0627\u062d \u0627\u0644\u0646\u0642\u062f\u064a\u0629 \u0644\u0634\u0631\u0627\u0621 \u0627\u0644\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u0623\u0633\u0647\u0645.</p>
      
      <h2 id="yield-on-cost">\u0627\u0644\u0639\u0627\u0626\u062f \u0639\u0644\u0649 \u0627\u0644\u062a\u0643\u0644\u0641\u0629</h2>
      <p>\u0625\u0630\u0627 \u0627\u0634\u062a\u0631\u064a\u062a \u0633\u0647\u0645\u0627\u064b \u0627\u0644\u064a\u0648\u0645 \u0628\u0633\u0639\u0631 100 \u0631\u064a\u0627\u0644 \u064a\u0648\u0632\u0639 3 \u0631\u064a\u0627\u0644\u0627\u062a (\u0639\u0627\u0626\u062f 3%)\u060c \u062b\u0645 \u0631\u0641\u0639 \u0627\u0644\u0633\u0647\u0645 \u062a\u0648\u0632\u064a\u0639\u0647 \u0628\u0639\u062f 10 \u0633\u0646\u0648\u0627\u062a \u0644\u064a\u0635\u0644 \u0644\u0640 15 \u0631\u064a\u0627\u0644\u0627\u064b\u060c \u0641\u0625\u0646 \u0639\u0627\u0626\u062f\u0643 "\u0627\u0644\u062d\u0642\u064a\u0642\u064a" \u0639\u0644\u0649 \u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0643 \u0627\u0644\u0623\u0635\u0644\u064a \u0647\u0648 15%\u060c \u0628\u063a\u0636 \u0627\u0644\u0646\u0638\u0631 \u0639\u0646 \u0633\u0639\u0631 \u0627\u0644\u0633\u0647\u0645 \u0627\u0644\u062d\u0627\u0644\u064a.</p>

      <div class="highlight-box">
        <h4>\ud83d\udcc8 \u0623\u0631\u0642\u0627\u0645 \u0644\u0627 \u062a\u0643\u0630\u0628</h4>
        <p>\u0627\u0633\u062a\u062b\u0645\u0627\u0631 10,000 \u0631\u064a\u0627\u0644 \u0641\u064a \u0634\u0631\u0643\u0629 \u062a\u0631\u0641\u0639 \u062a\u0648\u0632\u064a\u0639\u0627\u062a\u0647\u0627 \u0628\u0646\u0633\u0628\u0629 10% \u0633\u0646\u0648\u064a\u0627\u064b \u0645\u0639 \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u060c \u0642\u062f \u064a\u062a\u062d\u0648\u0644 \u0625\u0644\u0649 \u062f\u062e\u0644 \u0634\u0647\u0631\u064a \u064a\u063a\u0637\u064a \u0645\u0635\u0627\u0631\u064a\u0641\u0643 \u0627\u0644\u0623\u0633\u0627\u0633\u064a\u0629 \u062e\u0644\u0627\u0644 15-20 \u0639\u0627\u0645\u0627\u064b.</p>
      </div>
    `,
    contentEn: `
      <h2 id="compounding-power">The Power of Compounding</h2>
      <p>Investing in dividend growers ensures inflation protection and steady passive income growth without selling your principle.</p>
      
      <h2 id="yield-on-cost">Yield on Cost (YOC)</h2>
      <p>YOC measures the dividend yield based on your original purchase price. After years of dividend raises, your YOC can easily reach double digits.</p>
    `
  },
