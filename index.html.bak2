    breadcrumb: "\u0627\u0644\u0639\u0645\u0644\u0627\u062a \u0627\u0644\u0631\u0642\u0645\u064a\u0629",
    breadcrumbEn: "Cryptocurrency",
    breadcrumbHref: "index.html#strategies",
    toc: [
      { id: "utility-vs-spec", text: "\u0627\u0644\u0645\u0646\u0641\u0639\u0629 \u0645\u0642\u0627\u0628\u0644 \u0627\u0644\u0645\u0636\u0627\u0631\u0628\u0629" },
      { id: "rwa-future", text: "\u0645\u0633\u062a\u0642\u0628\u0644 \u0627\u0644\u0640 RWA \u0648\u062a\u063a\u064a\u064a\u0631 \u0627\u0644\u062a\u0645\u0648\u064a\u0644" },
      { id: "legal-bridging", text: "\u0627\u0644\u062c\u0633\u0631 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a \u0628\u064a\u0646 \u0627\u0644\u0623\u0635\u0648\u0644 \u0627\u0644\u0631\u0642\u0645\u064a\u0629 \u0648\u0627\u0644\u0641\u064a\u0632\u064a\u0627\u0626\u064a\u0629" },
