    title: "\u0627\u0644\u0645\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u062e\u0641\u064a: \u0641\u0647\u0645 \u062a\u0631\u0627\u0643\u0645 \u0627\u0644\u0630\u0647\u0628 \u0641\u064a \u0627\u0644\u0645\u0635\u0627\u0631\u0641 \u0627\u0644\u0645\u0631\u0643\u0632\u064a\u0629 \u0643\u0625\u0634\u0627\u0631\u0629 \u0644\u0644\u0633\u0648\u0642",
    titleEn: "The Central Bank Frontrunner: Understanding Sovereign Bullion Accumulation",
    summary: "\u0644\u0645\u0627\u0630\u0627 \u062a\u0634\u062a\u0631\u064a \u0627\u0644\u0635\u064a\u0646 \u0648\u0631\u0648\u0633\u064a\u0627 \u0648\u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0627\u0644\u0630\u0647\u0628 \u0628\u0643\u0645\u064a\u0627\u062a \u0642\u064a\u0627\u0633\u064a\u0629\u061f \u0627\u0643\u062a\u0634\u0641 \u0643\u064a\u0641 \u062a\u0633\u062a\u062e\u062f\u0645 \u062a\u062d\u0631\u0643\u0627\u062a \u0627\u0644\u0628\u0646\u0648\u0643 \u0627\u0644\u0645\u0631\u0643\u0632\u064a\u0629 \u0643\u0628\u0648\u0635\u0644\u0629 \u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a\u0643 \u0627\u0644\u062e\u0627\u0635\u0629.",
