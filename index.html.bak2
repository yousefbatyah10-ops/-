    id: 40,
    slug: "trusts-offshore-entities-protection",
    title: "\u0635\u0646\u0627\u062f\u064a\u0642 \u0627\u0644\u0627\u0645\u0627\u0646\u0627\u062a \u0648\u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629: \u0627\u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629 \u0645\u0642\u0627\u0628\u0644 \u0627\u0644\u0645\u0633\u0624\u0648\u0644\u064a\u0629 \u0627\u0644\u0623\u062e\u0644\u0627\u0642\u064a\u0629",
    titleEn: "Trusts and Offshore Entities: Legal Protection vs. Ethical Responsibility",
    summary: "\u062f\u0644\u064a\u0644 \u0645\u062a\u0642\u062f\u0645 \u0641\u064a \u0647\u064a\u0643\u0644\u0629 \u0627\u0644\u062b\u0631\u0648\u0627\u062a. \u0643\u064a\u0641 \u062a\u0633\u062a\u062e\u062f\u0645 \u0635\u0646\u0627\u062f\u064a\u0642 \u0627\u0644\u0627\u0626\u062a\u0645\u0627\u0646 (Trusts) \u0644\u062d\u0645\u0627\u064a\u0629 \u0623\u0635\u0648\u0644\u0643 \u0645\u0646 \u0627\u0644\u0645\u0637\u0627\u0644\u0628\u0627\u062a \u0648\u0628\u0646\u0627\u0621 \u062c\u062f\u0627\u0631 \u0642\u0627\u0646\u0648\u0646\u064a \u0645\u0646\u064a\u0639 \u062d\u0648\u0644 \u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a\u0643.",
    summaryEn: "Advanced wealth structuring guide. Using trusts to protect assets and build legal walls.",
    excerpt: "\u0628\u0639\u064a\u062f\u0627\u064b \u0639\u0646 \u0627\u0644\u0623\u0648\u0647\u0627\u0645\u060c \u0646\u0634\u0631\u062d \u0627\u0644\u0622\u0644\u064a\u0627\u062a \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629 \u0627\u0644\u062d\u0642\u064a\u0642\u064a\u0629 \u0644\u0644\u0647\u064a\u0643\u0644\u0629 \u0639\u0627\u0628\u0631\u0629 \u0627\u0644\u062d\u062f\u0648\u062f \u0648\u0643\u064a\u0641 \u062a\u062e\u062a\u0627\u0631 \u0627\u0644\u0633\u0644\u0637\u0627\u062a \u0627\u0644\u0642\u0636\u0627\u0626\u064a\u0629 (Jurisdictions) \u0627\u0644\u0623\u0643\u062b\u0631 \u0623\u0645\u0627\u0646\u0627\u064b \u0644\u062b\u0631\u0648\u0629 \u0639\u0627\u0626\u0644\u062a\u0643.",
