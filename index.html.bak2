<!-- Hero Section -->
<section class="hero" id="hero" aria-labelledby="hero-title">
  <div class="hero-bg" aria-hidden="true"></div>
  <svg class="hero-chart" aria-hidden="true"></svg>

  <div class="hero-content">
    <div class="hero-text">
      <div class="hero-badge">
        <span class="dot" aria-hidden="true"></span>
        <span data-i18n="hero.badge">منصة النخبة المالية العربية</span>
      </div>
      <h1 class="hero-title" id="hero-title">
        <span data-i18n="hero.title.line1">استثمر بذكاء،</span>
        <br>
        <span class="accent" data-i18n="hero.title.accent">ابنِ ثروتك</span>
        <br>
        <span data-i18n="hero.title.line2">بثقة</span>
      </h1>
      <p class="hero-desc" data-i18n="hero.desc">
        تحليلات مالية عمقية، استراتيجيات استثمار مجرّبة، ورؤى نخبة من الخبراء — كل ما يحتاجه المستثمر العربي الطموح في مكان واحد.
      </p>
      <div class="hero-actions">
        <a href="#articles" class="btn-primary" id="hero-explore-btn">
          <span data-i18n="hero.btn.articles">استكشف المقالات</span>
          <span aria-hidden="true">←</span>
        </a>
        <a href="#newsletter" class="btn-secondary" id="hero-subscribe-btn">
          <span data-i18n="hero.btn.newsletter">اشترك مجاناً</span>
          <span aria-hidden="true">❆</span>
        </a>
      </div>
      <div class="hero-stats" role="list" aria-label="إحصائيات الملتقى">
        <div class="stat-item" role="listitem">
          <span class="stat-num" data-target="12" data-suffix="K+">12K+</span>
          <span class="stat-label" data-i18n="hero.stat.readers">مستثمر نشط</span>
        </div>
        <div class="stat-item" role="listitem">
          <span class="stat-num" data-target="40" data-suffix="+">40+</span>
          <span class="stat-label" data-i18n="hero.stat.articles">مقالة متخصصة</span>
        </div>
        <div class="stat-item" role="listitem">
          <span class="stat-num" data-target="4.9" data-suffix="★">4.9★</span>
          <span class="stat-label" data-i18n="hero.stat.years">تقييم القراء</span>
        </div>
      </div>
    </div>

    <!-- البطاقة العائمة -->
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-card-float">
        <div class="card-header-mini">
          <div class="card-avatar">📈</div>
          <div>
            <div class="card-title-mini" data-i18n="hero.card.title">محفظتي هذا الشهر</div>
            <div class="card-sub-mini" data-i18n="hero.card.sub">أداء نمو الاستثمارات</div>
          </div>
        </div>
        <svg class="mini-chart"></svg>
        <div class="mini-stats">
          <div class="mini-stat">
            <span class="mini-stat-val up">+18.4%</span>
            <span class="mini-stat-label" data-i18n="hero.card.growth">الأسهم</span>
          </div>
          <div class="mini-stat">
            <span class="mini-stat-val up">+7.2%</span>
            <span class="mini-stat-label" data-i18n="hero.card.return">العقارات</span>
          </div>
          <div class="mini-stat">
            <span class="mini-stat-val up">+12.1%</span>
            <span class="mini-stat-label" data-i18n="hero.card.risk">الذهب</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- أحدث المقالات -->
<section id="articles" aria-labelledby="articles-title">
  <div class="container">
    <div class="section-header">
      <div class="section-tag" data-i18n="section.articles.tag">❖ أحدث المقالات</div>
      <h2 class="section-title" id="articles-title">
        <span data-i18n="section.articles.title1">رؤى مالية</span> <span data-i18n="section.articles.title2">حصرية</span>
      </h2>
      <p class="section-desc" data-i18n="section.articles.desc">محتوى متخصص يكتبه خبراء ماليون بخبرة عقود في أسواق المال العربية والعالمية</p>
    </div>
    <div class="filter-container">
      <div class="filter-bar" id="categoryFilter">
        <button class="filter-btn active" data-category="all" data-i18n="filter.all">الكل</button>
        <button class="filter-btn" data-category="stocks" data-i18n="cat.stocks">الأسهم</button>
        <button class="filter-btn" data-category="realestate" data-i18n="cat.realestate">العقارات</button>
        <button class="filter-btn" data-category="gold" data-i18n="cat.gold">الذهب والمعادن</button>
        <button class="filter-btn" data-category="crypto" data-i18n="cat.crypto">العملات الرقمية</button>
        <button class="filter-btn" data-category="startup" data-i18n="cat.startup">ريادة الأعمال</button>
        <button class="filter-btn" data-category="passive" data-i18n="cat.passive">الدخل السلبي</button>
        <button class="filter-btn" data-category="personal" data-i18n="cat.personal">المالية الشخصية</button>
        <button class="filter-btn" data-category="tech" data-i18n="cat.tech">تقنية وثروة</button>
      </div>
    </div>

    <div class="articles-grid" id="articlesGrid">
      <!-- تُملأ ديناميكياً من articles.js -->
    </div>

    <div style="text-align: center; margin-top: 3rem;">
      <a href="#" class="btn-secondary" id="load-more-btn" data-i18n="articles.loadmore">
        عرض المزيد من المقالات ↓
      </a>
    </div>
  </div>
</section>

<!-- قسم المقالات (التصنيفات) -->
