    slug: "platinum-palladium-hydrogen-future",
    title: "\u0627\u0644\u0628\u0644\u0627\u062a\u064a\u0646 \u0648\u0627\u0644\u0628\u0644\u0627\u062f\u064a\u0648\u0645: \u0627\u0644\u0631\u0647\u0627\u0646 \u0639\u0644\u0649 \u0645\u0633\u062a\u0642\u0628\u0644 \u0627\u0644\u0647\u064a\u062f\u0631\u0648\u062c\u064a\u0646 \u0648\u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0646\u0638\u064a\u0641\u0629",
    titleEn: "Platinum & Palladium: Betting on the Hydrogen Future",
    summary: "\u0627\u0644\u0645\u0639\u0627\u062f\u0646 \u0627\u0644\u062b\u0645\u064a\u0646\u0629 \u0644\u064a\u0633\u062a \u0630\u0647\u0628\u0627\u064b \u0641\u0642\u0637. \u0644\u0645\u0627\u0630\u0627 \u064a\u0639\u062a\u0628\u0631 \u0627\u0644\u0628\u0644\u0627\u062a\u064a\u0646 \u0647\u0648 \u0627\u0644\u0639\u0646\u0635\u0631 \u0627\u0644\u062d\u0627\u0633\u0645 \u0641\u064a \u062e\u0644\u0627\u064a\u0627 \u0627\u0644\u0648\u0642\u0648\u062f \u0627\u0644\u0647\u064a\u062f\u0631\u0648\u062c\u064a\u0646\u064a \u0648\u0643\u064a\u0641 \u062a\u062a\u0645\u0631\u0643\u0632 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u0648\u0627\u0639\u062f.",
