    title: "\u0627\u0644\u062a\u0623\u0645\u064a\u0646 \u0627\u0644\u0628\u062f\u064a\u0644: \u062d\u0645\u0627\u064a\u0629 \u0623\u0635\u0648\u0644\u0643 \u0627\u0644\u0631\u0642\u0645\u064a\u0629 \u0648\u0627\u0644\u0633\u064a\u0628\u0631\u0627\u0646\u064a\u0629 \u0641\u064a \u0639\u0627\u0644\u0645 \u063a\u064a\u0631 \u0645\u0633\u062a\u0642\u0631",
    titleEn: "Alternative Insurance: Protecting Digital Risks",
    summary: "\u0645\u0627\u0630\u0627 \u0644\u0648 \u062a\u0639\u0631\u0636\u062a \u0644\u0644\u0642\u0631\u0635\u0646\u0629 \u0623\u0648 \u0641\u0642\u062f\u062a \u0623\u0635\u0648\u0644\u0643 \u0627\u0644\u0645\u0634\u0641\u0631\u0629\u061f \u0627\u0633\u062a\u0639\u0631\u0627\u0636 \u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u062a\u0623\u0645\u064a\u0646 \u0627\u0644\u062d\u062f\u064a\u062b\u0629 \u0627\u0644\u062a\u064a \u062a\u062d\u0645\u064a \u062b\u0631\u0648\u062a\u0643 \u0645\u0646 \u0627\u0644\u0623\u062e\u0637\u0627\u0631 \u063a\u064a\u0631 \u0627\u0644\u062a\u0642\u0644\u064a\u062f\u064a\u0629.",
    summaryEn: "What if you're hacked or lose crypto? Reviewing modern insurance products that protect wealth from non-traditional risks.",
    excerpt: "\u0641\u064a \u0627\u0644\u0639\u0635\u0631 \u0627\u0644\u0631\u0642\u0645\u064a\u060c \u0627\u0644\u062a\u0623\u0645\u064a\u0646 \u0639\u0644\u0649 \u0627\u0644\u0645\u0646\u0632\u0644 \u0648\u0627\u0644\u0633\u064a\u0627\u0631\u0629 \u0644\u0627 \u064a\u0643\u0641\u064a. \u0627\u0643\u062a\u0634\u0641 \u0643\u064a\u0641 \u064a\u0624\u0645\u0646 \u0643\u0628\u0627\u0631 \u0627\u0644\u0645\u0633\u062a\u062b\u0645\u0631\u064a\u0646 '\u0645\u062d\u0627\u0641\u0638\u0647\u0645 \u0627\u0644\u0631\u0642\u0645\u064a\u0629' \u0648\u0647\u0648\u064a\u062a\u0647\u0645 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a\u0629 \u0645\u0646 \u0627\u0644\u062a\u0647\u062f\u064a\u062f\u0627\u062a \u0627\u0644\u0633\u064a\u0628\u0631\u0627\u0646\u064a\u0629.",
