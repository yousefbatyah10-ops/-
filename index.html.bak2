      { id: "rollups", text: "\u0627\u0644\u0631\u0648\u0644-\u0623\u0628 (Rollups): \u0627\u0644\u062a\u0641\u0627\u0624\u0644\u064a\u0629 \u0645\u0642\u0627\u0628\u0644 ZK" },
      { id: "ecosystem-growth", text: "\u0646\u0645\u0648 \u0627\u0644\u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u0628\u064a\u0626\u064a\u0629" },
